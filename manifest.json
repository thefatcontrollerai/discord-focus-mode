{
  "manifest_version": 3,
  "name": "Discord Focus Mode",
  "description": "Toggle Discord sidebars for a full-width chat terminal. Press Alt+H or click the toolbar icon.",
  "version": "1.0.0",
  "permissions": ["storage", "scripting", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://discord.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Discord Focus Mode",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
